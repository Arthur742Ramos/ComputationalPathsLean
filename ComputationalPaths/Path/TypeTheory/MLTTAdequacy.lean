/-
# Bounded raw MLTT adequacy for computational paths

This module combines two complementary, deliberately bounded results for the
predicative Martin-Lof fragment generated by dependent products, dependent
sums, lifted natural numbers, Tarski universe codes, and identity types.

First, the semantic CwF below interprets contexts as Lean types,
substitutions as functions, types as families, and terms as sections.  Identity
proofs are refined to `Path` values and their named groupoid reductions are
validated by `RwEq`.

Second, `RawMLTT` supplies an independent de Bruijn-scoped source calculus.
Renaming and simultaneous substitution traverse explicit binder lifts; raw
typing and beta computation cover every in-scope type former; and the
compositional term-model interpretation is substitution compatible.  Its
identity-program constructors contain only source `DefEq` evidence and source
one-hole frames.  Target `Path.Step` and `RwEq` constructors appear solely in
the proof of semantic soundness, never as a source-rule escape hatch.

## Main results

* `substitution_adequacy`: substitution is strictly preserved by the fragment.
* `identity_rweq_sound`: typed identity rewrites evaluate to `RwEq`.
* `endpoint_adequacy`: a computational path exists exactly when its endpoints
  are propositionally equal.
* `RawMLTT.raw_computational_path_adequacy`: scoped raw typing, computation,
  substitution, identity-rewrite soundness, and exact term-model endpoint
  conservativity.
* `computational_path_adequacy`: packages the model, rewrite, endpoint, and
  raw-syntax results into one public certificate.
* `no_traceSensitiveJ`: unrestricted elimination over raw trace metadata is
  impossible.  The supported eliminator is `proofInsensitiveJ`, whose motive
  sees the underlying equality proof rather than the `steps` list.

## Scope

This is not an interpretation of univalence, higher inductive types, or full
HoTT, and it does not claim that raw `Path` is the HoTT identity type.  The
positive raw theorem is a term-model adequacy/conservativity theorem for the
stated bounded calculus, not normalization, canonicity, decidable type
checking, or initiality.  Equality-factored `J` is supported because its motive
sees only Lean equality.  Ordinary `J` over observable `Path.steps` is refuted
below.  A future univalent/HIT model must therefore change or quotient the
trace-sensitive identity representation rather than silently strengthening
this result.

## References

* Martin-Lof, *Intuitionistic Type Theory*.
* Dybjer, *Internal Type Theory*.
* de Queiroz et al., *Propositional equality, identity types, and direct
  computational paths*.
-/

import ComputationalPaths.Path.Rewrite.Quot
import ComputationalPaths.Path.TypeTheory.RawSemantics

namespace ComputationalPaths
namespace Path
namespace TypeTheory
namespace MLTTAdequacy

universe u v

noncomputable section

/-! ## The semantic fragment -/

/-- Contexts in the interpreted fragment. -/
abbrev SemCtx := Type u

/-- Substitutions in the interpreted fragment. -/
abbrev SemSub (Delta Gamma : Type u) := Delta -> Gamma

/-- Types in context in the interpreted fragment. -/
abbrev SemTy (Gamma : Type u) := Gamma -> Type u

/-- Intrinsically typed terms in the interpreted fragment. -/
abbrev SemTm (Gamma : Type u) (A : SemTy Gamma) := (gamma : Gamma) -> A gamma

/-- Identity substitution. -/
def semSubId (Gamma : Type u) : SemSub Gamma Gamma := fun gamma => gamma

/-- Composition of substitutions. -/
def semSubComp {Gamma Delta Theta : Type u}
    (sigma : SemSub Delta Gamma) (tau : SemSub Theta Delta) :
    SemSub Theta Gamma :=
  fun theta => sigma (tau theta)

/-- Substitution action on types. -/
def semTySub {Gamma Delta : Type u}
    (A : SemTy Gamma) (sigma : SemSub Delta Gamma) : SemTy Delta :=
  fun delta => A (sigma delta)

/-- Substitution action on terms. -/
def semTmSub {Gamma Delta : Type u} {A : SemTy Gamma}
    (t : SemTm Gamma A) (sigma : SemSub Delta Gamma) :
    SemTm Delta (semTySub A sigma) :=
  fun delta => t (sigma delta)

/-- Context comprehension. -/
def semCtxExt (Gamma : Type u) (A : SemTy Gamma) : Type u :=
  (gamma : Gamma) × A gamma

/-- Computational-path identity type in context. -/
def semIdTy {Gamma : Type u} {A : SemTy Gamma}
    (a b : SemTm Gamma A) : SemTy Gamma :=
  fun gamma => Path (a gamma) (b gamma)

/-- Reflexivity introduction for the identity type. -/
def semIdRefl {Gamma : Type u} {A : SemTy Gamma}
    (a : SemTm Gamma A) : SemTm Gamma (semIdTy a a) :=
  fun gamma => Path.refl (a gamma)

/-- Dependent-sum type former. -/
def semSigmaTy {Gamma : Type u} (A : SemTy Gamma)
    (B : SemTy (semCtxExt Gamma A)) : SemTy Gamma :=
  fun gamma => (a : A gamma) × B ⟨gamma, a⟩

/-- Dependent-pair introduction. -/
def semSigmaPair {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (a : SemTm Gamma A)
    (b : SemTm Gamma (fun gamma => B ⟨gamma, a gamma⟩)) :
    SemTm Gamma (semSigmaTy A B) :=
  fun gamma => ⟨a gamma, b gamma⟩

/-- First projection from a dependent pair. -/
def semSigmaFst {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (t : SemTm Gamma (semSigmaTy A B)) : SemTm Gamma A :=
  fun gamma => (t gamma).1

/-- Second projection from a dependent pair. -/
def semSigmaSnd {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (t : SemTm Gamma (semSigmaTy A B)) :
    SemTm Gamma (fun gamma => B ⟨gamma, semSigmaFst t gamma⟩) :=
  fun gamma => (t gamma).2

/-- Dependent-product type former. -/
def semPiTy {Gamma : Type u} (A : SemTy Gamma)
    (B : SemTy (semCtxExt Gamma A)) : SemTy Gamma :=
  fun gamma => (a : A gamma) -> B ⟨gamma, a⟩

/-- Lambda introduction for dependent products. -/
def semPiLam {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (body : SemTm (semCtxExt Gamma A) B) :
    SemTm Gamma (semPiTy A B) :=
  fun gamma a => body ⟨gamma, a⟩

/-- Application elimination for dependent products. -/
def semPiApp {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (f : SemTm Gamma (semPiTy A B)) (a : SemTm Gamma A) :
    SemTm Gamma (fun gamma => B ⟨gamma, a gamma⟩) :=
  fun gamma => f gamma (a gamma)

/-- Lifted natural numbers as a constant type in context. -/
abbrev semNatTy (Gamma : Type u) : SemTy Gamma := fun _ => ULift.{u} Nat

/-- Zero introduction. -/
def semZero (Gamma : Type u) : SemTm Gamma (semNatTy Gamma) :=
  fun _ => ULift.up Nat.zero

/-- Successor introduction. -/
def semSucc {Gamma : Type u} (n : SemTm Gamma (semNatTy Gamma)) :
    SemTm Gamma (semNatTy Gamma) :=
  fun gamma => ULift.up (Nat.succ (n gamma).down)

/-! ## Predicative universe codes -/

/-- A Tarski-style code for a type in `Type u`.

The code object itself lives one universe higher.  This keeps the construction
predicative and avoids any resizing or univalence assumption. -/
structure UniverseCode where
  carrier : Type u

namespace UniverseCode

/-- Decode a universe code. -/
abbrev El (U : UniverseCode.{u}) : Type u := U.carrier

/-- Code for natural numbers, lifted into the ambient universe. -/
def nat : UniverseCode.{u} := ⟨ULift.{u} Nat⟩

/-- Code for the unit type, lifted into the ambient universe. -/
def unit : UniverseCode.{u} := ⟨ULift.{u} Unit⟩

/-- Dependent-product code. -/
def pi (A : UniverseCode.{u}) (B : El A -> UniverseCode.{u}) :
    UniverseCode.{u} :=
  ⟨(a : El A) -> El (B a)⟩

/-- Dependent-sum code. -/
def sigma (A : UniverseCode.{u}) (B : El A -> UniverseCode.{u}) :
    UniverseCode.{u} :=
  ⟨(a : El A) × El (B a)⟩

/-- Identity code, interpreted by computational paths. -/
def identity (A : UniverseCode.{u}) (a b : El A) : UniverseCode.{u} :=
  ⟨Path a b⟩

@[simp] theorem el_nat :
    El (nat : UniverseCode.{u}) = ULift.{u} Nat := rfl

@[simp] theorem el_unit :
    El (unit : UniverseCode.{u}) = ULift.{u} Unit := rfl

@[simp] theorem el_pi (A : UniverseCode.{u}) (B : El A -> UniverseCode.{u}) :
    El (pi A B) = ((a : El A) -> El (B a)) := rfl

@[simp] theorem el_sigma (A : UniverseCode.{u}) (B : El A -> UniverseCode.{u}) :
    El (sigma A B) = ((a : El A) × El (B a)) := rfl

@[simp] theorem el_identity (A : UniverseCode.{u}) (a b : El A) :
    El (identity A a b) = Path a b := rfl

end UniverseCode

/-- Decode a context-indexed family of universe codes. -/
def decodeTy {Gamma : Type u} (U : Gamma -> UniverseCode.{u}) : SemTy Gamma :=
  fun gamma => (U gamma).El

@[simp] theorem decodeTy_substitution {Gamma Delta : Type u}
    (U : Gamma -> UniverseCode.{u}) (sigma : SemSub Delta Gamma) :
    semTySub (decodeTy U) sigma = decodeTy (fun delta => U (sigma delta)) :=
  rfl

/-! ## Natural-number elimination -/

/-- Pointwise natural-number elimination in the semantic CwF. -/
def natElim {Gamma : Type u}
    (C : (gamma : Gamma) -> Nat -> Type u)
    (zeroCase : (gamma : Gamma) -> C gamma 0)
    (succCase : (gamma : Gamma) -> (n : Nat) -> C gamma n -> C gamma (n + 1))
    (n : SemTm Gamma (semNatTy Gamma)) :
    (gamma : Gamma) -> C gamma (n gamma).down :=
  fun gamma =>
    Nat.rec (zeroCase gamma) (fun k ih => succCase gamma k ih) (n gamma).down

@[simp] theorem natElim_zero {Gamma : Type u}
    (C : (gamma : Gamma) -> Nat -> Type u)
    (zeroCase : (gamma : Gamma) -> C gamma 0)
    (succCase : (gamma : Gamma) -> (n : Nat) -> C gamma n -> C gamma (n + 1))
    (gamma : Gamma) :
    natElim C zeroCase succCase (semZero Gamma) gamma = zeroCase gamma :=
  rfl

@[simp] theorem natElim_succ {Gamma : Type u}
    (C : (gamma : Gamma) -> Nat -> Type u)
    (zeroCase : (gamma : Gamma) -> C gamma 0)
    (succCase : (gamma : Gamma) -> (n : Nat) -> C gamma n -> C gamma (n + 1))
    (n : SemTm Gamma (semNatTy Gamma)) (gamma : Gamma) :
    natElim C zeroCase succCase (semSucc n) gamma =
      succCase gamma (n gamma).down (natElim C zeroCase succCase n gamma) :=
  rfl

@[simp] theorem natElim_substitution {Gamma Delta : Type u}
    (C : (gamma : Gamma) -> Nat -> Type u)
    (zeroCase : (gamma : Gamma) -> C gamma 0)
    (succCase : (gamma : Gamma) -> (n : Nat) -> C gamma n -> C gamma (n + 1))
    (n : SemTm Gamma (semNatTy Gamma)) (sigma : SemSub Delta Gamma) :
    (fun delta => natElim C zeroCase succCase n (sigma delta)) =
      natElim
        (fun delta k => C (sigma delta) k)
        (fun delta => zeroCase (sigma delta))
        (fun delta k ih => succCase (sigma delta) k ih)
        (semTmSub n sigma) :=
  rfl

/-! ## Type-former computation laws -/

@[simp] theorem sigma_fst_beta {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (a : SemTm Gamma A)
    (b : SemTm Gamma (fun gamma => B ⟨gamma, a gamma⟩)) :
    semSigmaFst (semSigmaPair a b) = a :=
  rfl

@[simp] theorem sigma_snd_beta {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (a : SemTm Gamma A)
    (b : SemTm Gamma (fun gamma => B ⟨gamma, a gamma⟩)) :
    semSigmaSnd (semSigmaPair a b) = b :=
  rfl

@[simp] theorem sigma_eta {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (t : SemTm Gamma (semSigmaTy A B)) :
    semSigmaPair (semSigmaFst t) (semSigmaSnd t) = t := by
  funext gamma
  change ⟨(t gamma).1, (t gamma).2⟩ = t gamma
  cases t gamma
  rfl

@[simp] theorem pi_beta {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (body : SemTm (semCtxExt Gamma A) B) (a : SemTm Gamma A) :
    semPiApp (semPiLam body) a = (fun gamma => body ⟨gamma, a gamma⟩) :=
  rfl

@[simp] theorem pi_eta {Gamma : Type u} {A : SemTy Gamma}
    {B : SemTy (semCtxExt Gamma A)}
    (f : SemTm Gamma (semPiTy A B)) :
    semPiLam (fun ⟨gamma, a⟩ => f gamma a) = f :=
  rfl

/-- Computation laws for all introduction and elimination operations in the
bounded fragment.  Their dependent types are the typing-preservation evidence. -/
structure TypeFormerAdequacy where
  sigma_first_beta :
    forall {Gamma : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)}
      (a : SemTm Gamma A)
      (b : SemTm Gamma (fun gamma => B ⟨gamma, a gamma⟩)),
      semSigmaFst (semSigmaPair a b) = a
  sigma_second_beta :
    forall {Gamma : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)}
      (a : SemTm Gamma A)
      (b : SemTm Gamma (fun gamma => B ⟨gamma, a gamma⟩)),
      semSigmaSnd (semSigmaPair a b) = b
  sigma_extensionality :
    forall {Gamma : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)}
      (t : SemTm Gamma (semSigmaTy A B)),
      semSigmaPair (semSigmaFst t) (semSigmaSnd t) = t
  pi_application_beta :
    forall {Gamma : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)}
      (body : SemTm (semCtxExt Gamma A) B) (a : SemTm Gamma A),
      semPiApp (semPiLam body) a = (fun gamma => body ⟨gamma, a gamma⟩)
  pi_extensionality :
    forall {Gamma : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)}
      (f : SemTm Gamma (semPiTy A B)),
      semPiLam (fun ⟨gamma, a⟩ => f gamma a) = f
  nat_zero_beta :
    forall {Gamma : Type u}
      (C : (gamma : Gamma) -> Nat -> Type u)
      (zeroCase : (gamma : Gamma) -> C gamma 0)
      (succCase :
        (gamma : Gamma) -> (n : Nat) -> C gamma n -> C gamma (n + 1))
      (gamma : Gamma),
      natElim C zeroCase succCase (semZero Gamma) gamma = zeroCase gamma
  nat_successor_beta :
    forall {Gamma : Type u}
      (C : (gamma : Gamma) -> Nat -> Type u)
      (zeroCase : (gamma : Gamma) -> C gamma 0)
      (succCase :
        (gamma : Gamma) -> (n : Nat) -> C gamma n -> C gamma (n + 1))
      (n : SemTm Gamma (semNatTy Gamma)) (gamma : Gamma),
      natElim C zeroCase succCase (semSucc n) gamma =
        succCase gamma (n gamma).down (natElim C zeroCase succCase n gamma)
  universe_pi_beta :
    forall (A : UniverseCode.{u}) (B : A.El -> UniverseCode.{u}),
      (UniverseCode.pi A B).El = ((a : A.El) -> (B a).El)
  universe_sigma_beta :
    forall (A : UniverseCode.{u}) (B : A.El -> UniverseCode.{u}),
      (UniverseCode.sigma A B).El = ((a : A.El) × (B a).El)
  universe_identity_beta :
    forall (A : UniverseCode.{u}) (a b : A.El),
      (UniverseCode.identity A a b).El = Path a b

/-- The semantic operations are intrinsically typed and satisfy their
computation rules definitionally. -/
def type_former_adequacy : TypeFormerAdequacy.{u} where
  sigma_first_beta := sigma_fst_beta
  sigma_second_beta := sigma_snd_beta
  sigma_extensionality := sigma_eta
  pi_application_beta := pi_beta
  pi_extensionality := pi_eta
  nat_zero_beta := natElim_zero
  nat_successor_beta := natElim_succ
  universe_pi_beta := UniverseCode.el_pi
  universe_sigma_beta := UniverseCode.el_sigma
  universe_identity_beta := UniverseCode.el_identity

/-! ## Strict substitution preservation -/

/-- The substitution laws required by the interpreted MLTT fragment. -/
structure SubstitutionAdequacy where
  substitution_identity :
    forall (Gamma : Type u), semSubId Gamma = (fun gamma => gamma)
  substitution_composition :
    forall {Gamma Delta Theta : Type u}
      (sigma : SemSub Delta Gamma) (tau : SemSub Theta Delta),
      semSubComp sigma tau = (fun theta => sigma (tau theta))
  type_identity :
    forall {Gamma : Type u} (A : SemTy Gamma),
      semTySub A (semSubId Gamma) = A
  type_composition :
    forall {Gamma Delta Theta : Type u} (A : SemTy Gamma)
      (sigma : SemSub Delta Gamma) (tau : SemSub Theta Delta),
      semTySub (semTySub A sigma) tau = semTySub A (semSubComp sigma tau)
  term_identity :
    forall {Gamma : Type u} {A : SemTy Gamma} (t : SemTm Gamma A),
      semTmSub t (semSubId Gamma) = t
  term_composition :
    forall {Gamma Delta Theta : Type u} {A : SemTy Gamma}
      (t : SemTm Gamma A) (sigma : SemSub Delta Gamma)
      (tau : SemSub Theta Delta),
      semTmSub (semTmSub t sigma) tau = semTmSub t (semSubComp sigma tau)
  sigma_stable :
    forall {Gamma Delta : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)} (sigma : SemSub Delta Gamma),
      semTySub (semSigmaTy A B) sigma =
        semSigmaTy (semTySub A sigma)
          (semTySub B (fun x => ⟨sigma x.1, x.2⟩))
  pi_stable :
    forall {Gamma Delta : Type u} {A : SemTy Gamma}
      {B : SemTy (semCtxExt Gamma A)} (sigma : SemSub Delta Gamma),
      semTySub (semPiTy A B) sigma =
        semPiTy (semTySub A sigma)
          (semTySub B (fun x => ⟨sigma x.1, x.2⟩))
  nat_stable :
    forall {Gamma Delta : Type u} (sigma : SemSub Delta Gamma),
      semTySub (semNatTy Gamma) sigma = semNatTy Delta
  identity_stable :
    forall {Gamma Delta : Type u} {A : SemTy Gamma}
      (a b : SemTm Gamma A) (sigma : SemSub Delta Gamma),
      semTySub (semIdTy a b) sigma =
        semIdTy (semTmSub a sigma) (semTmSub b sigma)
  universe_stable :
    forall {Gamma Delta : Type u} (U : Gamma -> UniverseCode.{u})
      (sigma : SemSub Delta Gamma),
      semTySub (decodeTy U) sigma = decodeTy (fun delta => U (sigma delta))

/-- Computational paths give a strict interpretation of substitution for every
type former in the bounded fragment. -/
def substitution_adequacy : SubstitutionAdequacy.{u} where
  substitution_identity := fun _ => rfl
  substitution_composition := fun _ _ => rfl
  type_identity := fun _ => rfl
  type_composition := fun _ _ _ => rfl
  term_identity := fun _ => rfl
  term_composition := fun _ _ _ => rfl
  sigma_stable := fun _ => rfl
  pi_stable := fun _ => rfl
  nat_stable := fun _ => rfl
  identity_stable := fun _ _ _ => rfl
  universe_stable := fun _ _ => rfl

/-! ## Typed semantic identity expressions -/

/-- A typed expression language internal to the semantic `Path` model.

This older semantic layer starts from already interpreted paths.  The
independent source language used by the adequacy theorem is
`RawMLTT.IdentityExpr`, whose atoms contain only source `DefEq` derivations. -/
inductive IdentityExpr {A : Type u} : A -> A -> Type (u + 1) where
  | atom {a b : A} (p : Path a b) : IdentityExpr a b
  | refl (a : A) : IdentityExpr a a
  | symm {a b : A} (p : IdentityExpr a b) : IdentityExpr b a
  | trans {a b c : A} (p : IdentityExpr a b) (q : IdentityExpr b c) :
      IdentityExpr a c

namespace IdentityExpr

/-- Evaluate an identity expression as a computational path. -/
def eval {A : Type u} {a b : A} : IdentityExpr a b -> Path a b
  | .atom p => p
  | .refl a => Path.refl a
  | .symm p => Path.symm p.eval
  | .trans p q => Path.trans p.eval q.eval

/-- Quote a primitive computational path as a semantic identity expression. -/
def quote {A : Type u} {a b : A} (p : Path a b) : IdentityExpr a b :=
  .atom p

@[simp] theorem eval_quote {A : Type u} {a b : A} (p : Path a b) :
    (quote p).eval = p := rfl

@[simp] theorem eval_refl {A : Type u} (a : A) :
    (IdentityExpr.refl a).eval = Path.refl a := rfl

@[simp] theorem eval_symm {A : Type u} {a b : A} (p : IdentityExpr a b) :
    (IdentityExpr.symm p).eval = Path.symm p.eval := rfl

@[simp] theorem eval_trans {A : Type u} {a b c : A}
    (p : IdentityExpr a b) (q : IdentityExpr b c) :
    (IdentityExpr.trans p q).eval = Path.trans p.eval q.eval := rfl

end IdentityExpr

/-! ## Domain-specific rewrites for identity expressions -/

/-- Core named groupoid rewrites for semantic identity expressions.

Unlike the earlier bounded prototype, this relation has no constructor that
embeds an arbitrary target `Path.Step`. -/
inductive IdentityStep {A : Type u} :
    {a b : A} -> IdentityExpr a b -> IdentityExpr a b -> Type (u + 1) where
  | symm_refl (a : A) :
      IdentityStep (.symm (.refl a)) (.refl a)
  | symm_symm {a b : A} (p : IdentityExpr a b) :
      IdentityStep (.symm (.symm p)) p
  | trans_refl_left {a b : A} (p : IdentityExpr a b) :
      IdentityStep (.trans (.refl a) p) p
  | trans_refl_right {a b : A} (p : IdentityExpr a b) :
      IdentityStep (.trans p (.refl b)) p
  | trans_symm {a b : A} (p : IdentityExpr a b) :
      IdentityStep (.trans p (.symm p)) (.refl a)
  | symm_trans {a b : A} (p : IdentityExpr a b) :
      IdentityStep (.trans (.symm p) p) (.refl b)
  | symm_trans_congr {a b c : A}
      (p : IdentityExpr a b) (q : IdentityExpr b c) :
      IdentityStep (.symm (.trans p q)) (.trans (.symm q) (.symm p))
  | trans_assoc {a b c d : A}
      (p : IdentityExpr a b) (q : IdentityExpr b c)
      (r : IdentityExpr c d) :
      IdentityStep (.trans (.trans p q) r) (.trans p (.trans q r))
  | symm_congr {a b : A} {p q : IdentityExpr a b} :
      IdentityStep p q -> IdentityStep (.symm p) (.symm q)
  | trans_congr_left {a b c : A} {p q : IdentityExpr a b}
      (r : IdentityExpr b c) :
      IdentityStep p q -> IdentityStep (.trans p r) (.trans q r)
  | trans_congr_right {a b c : A} (p : IdentityExpr a b)
      {q r : IdentityExpr b c} :
      IdentityStep q r -> IdentityStep (.trans p q) (.trans p r)

/-- Symmetric reflexive-transitive closure of `IdentityStep`. -/
inductive IdentityRwEq {A : Type u} {a b : A} :
    IdentityExpr a b -> IdentityExpr a b -> Type (u + 1) where
  | refl (p : IdentityExpr a b) : IdentityRwEq p p
  | step {p q : IdentityExpr a b} : IdentityStep p q -> IdentityRwEq p q
  | symm {p q : IdentityExpr a b} : IdentityRwEq p q -> IdentityRwEq q p
  | trans {p q r : IdentityExpr a b} :
      IdentityRwEq p q -> IdentityRwEq q r -> IdentityRwEq p r

/-- Every named semantic identity rewrite is sound for the LND_EQ-TRS
relation. -/
def identityStep_sound {A : Type u} {a b : A}
    {p q : IdentityExpr a b} (h : IdentityStep p q) :
    RwEq p.eval q.eval := by
  induction h with
  | symm_refl a =>
      exact rweq_of_step (Path.Step.symm_refl a)
  | symm_symm p =>
      exact rweq_of_step (Path.Step.symm_symm p.eval)
  | trans_refl_left p =>
      exact rweq_of_step (Path.Step.trans_refl_left p.eval)
  | trans_refl_right p =>
      exact rweq_of_step (Path.Step.trans_refl_right p.eval)
  | trans_symm p =>
      exact rweq_of_step (Path.Step.trans_symm p.eval)
  | symm_trans p =>
      exact rweq_of_step (Path.Step.symm_trans p.eval)
  | symm_trans_congr p q =>
      exact rweq_of_step (Path.Step.symm_trans_congr p.eval q.eval)
  | trans_assoc p q r =>
      exact rweq_of_step (Path.Step.trans_assoc p.eval q.eval r.eval)
  | symm_congr _ ih =>
      exact rweq_symm_congr ih
  | trans_congr_left r _ ih =>
      exact rweq_trans_congr_left r.eval ih
  | trans_congr_right p _ ih =>
      exact rweq_trans_congr_right p.eval ih

/-- Rewrite equivalence of semantic identity expressions is interpreted by
rewrite equivalence of computational paths. -/
def identity_rweq_sound {A : Type u} {a b : A}
    {p q : IdentityExpr a b} (h : IdentityRwEq p q) :
    RwEq p.eval q.eval := by
  induction h with
  | refl p => exact rweq_refl p.eval
  | step h => exact identityStep_sound h
  | symm _ ih => exact rweq_symm ih
  | trans _ _ ih1 ih2 => exact rweq_trans ih1 ih2

/-! ## Composition, inverse, and fourfold semantic coherence -/

/-- The short reassociation route for four composable identity expressions. -/
def fourfold_reassociation {A : Type u} {a b c d e : A}
    (p : IdentityExpr a b) (q : IdentityExpr b c)
    (r : IdentityExpr c d) (s : IdentityExpr d e) :
    IdentityRwEq
      (.trans (.trans (.trans p q) r) s)
      (.trans p (.trans q (.trans r s))) :=
  IdentityRwEq.trans
    (IdentityRwEq.step (IdentityStep.trans_assoc (.trans p q) r s))
    (IdentityRwEq.step (IdentityStep.trans_assoc p q (.trans r s)))

/-- The long reassociation route for four composable identity expressions. -/
def fourfold_reassociation_alt {A : Type u} {a b c d e : A}
    (p : IdentityExpr a b) (q : IdentityExpr b c)
    (r : IdentityExpr c d) (s : IdentityExpr d e) :
    IdentityRwEq
      (.trans (.trans (.trans p q) r) s)
      (.trans p (.trans q (.trans r s))) :=
  IdentityRwEq.trans
    (IdentityRwEq.step
      (IdentityStep.trans_congr_left s (IdentityStep.trans_assoc p q r)))
    (IdentityRwEq.trans
      (IdentityRwEq.step (IdentityStep.trans_assoc p (.trans q r) s))
      (IdentityRwEq.step
        (IdentityStep.trans_congr_right p (IdentityStep.trans_assoc q r s))))

/-- Both standard fourfold associativity routes carry genuine `RwEq`
certificates after interpretation.

This record does not assert equality of the two derivations; such an equality
would be a separate pentagon 2-cell theorem. -/
structure FourfoldRouteCertificate {A : Type u} {a b c d e : A}
    (p : IdentityExpr a b) (q : IdentityExpr b c)
    (r : IdentityExpr c d) (s : IdentityExpr d e) where
  shortRoute :
    IdentityRwEq
      (.trans (.trans (.trans p q) r) s)
      (.trans p (.trans q (.trans r s)))
  longRoute :
    IdentityRwEq
      (.trans (.trans (.trans p q) r) s)
      (.trans p (.trans q (.trans r s)))
  shortRoute_sound :
    RwEq
      (Path.trans (Path.trans (Path.trans p.eval q.eval) r.eval) s.eval)
      (Path.trans p.eval (Path.trans q.eval (Path.trans r.eval s.eval)))
  longRoute_sound :
    RwEq
      (Path.trans (Path.trans (Path.trans p.eval q.eval) r.eval) s.eval)
      (Path.trans p.eval (Path.trans q.eval (Path.trans r.eval s.eval)))

/-- Construct the certificate containing both fourfold reassociation routes. -/
def fourfold_routes {A : Type u} {a b c d e : A}
    (p : IdentityExpr a b) (q : IdentityExpr b c)
    (r : IdentityExpr c d) (s : IdentityExpr d e) :
    FourfoldRouteCertificate p q r s where
  shortRoute := fourfold_reassociation p q r s
  longRoute := fourfold_reassociation_alt p q r s
  shortRoute_sound := identity_rweq_sound (fourfold_reassociation p q r s)
  longRoute_sound := identity_rweq_sound (fourfold_reassociation_alt p q r s)

/-! ## Endpoint adequacy and conservativity -/

/-- A pointwise equality judgment in a context. -/
abbrev EqJudgment {Gamma : Type u} {A : SemTy Gamma}
    (a b : SemTm Gamma A) : Prop :=
  forall gamma, a gamma = b gamma

/-- A pointwise computational-path judgment in a context. -/
abbrev PathJudgment {Gamma : Type u} {A : SemTy Gamma}
    (a b : SemTm Gamma A) :=
  (gamma : Gamma) -> Path (a gamma) (b gamma)

/-- Translate endpoint equality into an explicit one-step computational path. -/
def eqToPathJudgment {Gamma : Type u} {A : SemTy Gamma}
    {a b : SemTm Gamma A} (h : EqJudgment a b) : PathJudgment a b :=
  fun gamma => Path.stepChain (h gamma)

/-- Forget traces from a computational-path judgment. -/
def pathToEqJudgment {Gamma : Type u} {A : SemTy Gamma}
    {a b : SemTm Gamma A} (p : PathJudgment a b) : EqJudgment a b :=
  fun gamma => (p gamma).toEq

@[simp] theorem pathToEq_after_eqToPath {Gamma : Type u} {A : SemTy Gamma}
    {a b : SemTm Gamma A} (h : EqJudgment a b) :
    pathToEqJudgment (eqToPathJudgment h) = h := by
  funext gamma
  rfl

@[simp] theorem eqToPath_after_pathToEq_semantics
    {Gamma : Type u} {A : SemTy Gamma}
    {a b : SemTm Gamma A} (p : PathJudgment a b) (gamma : Gamma) :
    (eqToPathJudgment (pathToEqJudgment p) gamma).toEq =
      (p gamma).toEq :=
  rfl

/-- Endpoint equality and inhabitation of the computational path type coincide. -/
theorem endpoint_adequacy {A : Type u} (a b : A) :
    Nonempty (Path a b) <-> a = b := by
  constructor
  · rintro ⟨p⟩
    exact p.toEq
  · intro h
    exact ⟨Path.stepChain h⟩

/-- The contextual version of endpoint adequacy. -/
theorem judgment_adequacy {Gamma : Type u} {A : SemTy Gamma}
    (a b : SemTm Gamma A) :
    Nonempty (PathJudgment a b) <-> EqJudgment a b := by
  constructor
  · rintro ⟨p⟩
    exact pathToEqJudgment p
  · intro h
    exact ⟨eqToPathJudgment h⟩

/-- Translation of equality judgments commutes strictly with substitution. -/
theorem equality_translation_substitution
    {Gamma Delta : Type u} {A : SemTy Gamma}
    {a b : SemTm Gamma A} (h : EqJudgment a b)
    (sigma : SemSub Delta Gamma) :
    eqToPathJudgment (a := semTmSub a sigma) (b := semTmSub b sigma)
      (fun delta => h (sigma delta)) =
    (fun delta => eqToPathJudgment h (sigma delta)) :=
  rfl

/-! ## Identity elimination and its exact boundary -/

/-- The elimination principle supported by computational paths.

The motive may depend on the endpoint and on the proof-irrelevant equality
component.  It intentionally cannot inspect `p.steps`. -/
def proofInsensitiveJ {A : Type u} {a : A}
    (C : (b : A) -> a = b -> Sort v)
    (reflCase : C a rfl) {b : A} (p : Path a b) :
    C b p.toEq := by
  cases p with
  | mk _ proof =>
      cases proof
      exact reflCase

@[simp] theorem proofInsensitiveJ_refl {A : Type u} {a : A}
    (C : (b : A) -> a = b -> Sort v)
    (reflCase : C a rfl) :
    proofInsensitiveJ C reflCase (Path.refl a) = reflCase :=
  rfl

/-- The supported eliminator is independent of trace metadata. -/
theorem proofInsensitiveJ_trace_irrelevant {A : Type u} {a b : A}
    (C : (b : A) -> a = b -> Sort v)
    (reflCase : C a rfl) (p q : Path a b) :
    proofInsensitiveJ C reflCase p = proofInsensitiveJ C reflCase q := by
  cases p with
  | mk _ hp =>
      cases q with
      | mk _ hq =>
          cases hp
          cases hq
          rfl

/-- Ordinary based path induction for raw `Path`, whose motive may inspect the
trace.  This is the standard shape of J specialized to `Prop`. -/
abbrev TraceSensitiveJAt {A : Type u} (a : A) : Prop :=
  forall (C : (b : A) -> Path a b -> Prop),
    C a (Path.refl a) ->
    forall {b : A} (p : Path a b), C b p

/-- A one-step reflexive trace used to separate raw `Path` from an identity type
generated solely by reflexivity. -/
def tracedRefl {A : Type u} (a : A) : Path a a :=
  Path.stepChain (rfl : a = a)

@[simp] theorem tracedRefl_steps {A : Type u} (a : A) :
    (tracedRefl a).steps = [_root_.ComputationalPaths.Step.mk a a rfl] :=
  rfl

/-- Raw computational paths cannot support unrestricted trace-sensitive J.

Choosing the motive "`steps` is empty" would force the explicit one-step loop
to have an empty trace, which is impossible. -/
theorem no_traceSensitiveJ {A : Type u} (a : A) :
    Not (TraceSensitiveJAt a) := by
  intro eliminate
  have hEmpty : (tracedRefl a).steps = [] :=
    eliminate (fun _ p => p.steps = []) rfl (tracedRefl a)
  simp [tracedRefl, Path.stepChain] at hEmpty

/-! ## Main adequacy certificate -/

/-- Certificate combining the semantic CwF validation and the independent raw
term-model adequacy result. -/
structure ComputationalPathAdequacy where
  type_formers : TypeFormerAdequacy.{u}
  substitution : SubstitutionAdequacy.{u}
  rewrite_sound :
    forall {A : Type u} {a b : A} {p q : IdentityExpr a b},
      IdentityRwEq p q -> RwEq p.eval q.eval
  raw_syntax : RawMLTT.RawAdequacyCertificate
  raw_identity_rewrite_sound :
    forall {n : Nat} {t s : RawMLTT.Expr n}
      {p q : RawMLTT.IdentityExpr t s},
      RawMLTT.IdentityRwEq p q -> RwEq p.eval q.eval
  raw_endpoint_conservativity :
    forall {n : Nat} (t s : RawMLTT.Expr n),
      Nonempty (Path (RawMLTT.denote t) (RawMLTT.denote s)) <->
        RawMLTT.DefEq t s
  endpoint_sound_complete :
    forall {A : Type u} (a b : A), Nonempty (Path a b) <-> a = b
  contextual_sound_complete :
    forall {Gamma : Type u} {A : SemTy Gamma}
      (a b : SemTm Gamma A),
      Nonempty (PathJudgment a b) <-> EqJudgment a b
  raw_eq_factored_identity_beta :
    forall {n : Nat} (motive : RawMLTT.Expr (n + 2))
      (reflCase a : RawMLTT.Expr n),
      Path
        (RawMLTT.denote
          (.eqJ motive reflCase a (.refl a)))
        (RawMLTT.denote reflCase)
  eq_factored_identity_beta :
    forall {A : Type u} {a : A}
      (C : (b : A) -> a = b -> Sort v)
      (reflCase : C a rfl),
      proofInsensitiveJ C reflCase (Path.refl a) = reflCase
  trace_sensitive_boundary :
    forall {A : Type u} (a : A), Not (TraceSensitiveJAt a)
  fourfold_routes :
    forall {A : Type u} {a b c d e : A}
      (p : IdentityExpr a b) (q : IdentityExpr b c)
      (r : IdentityExpr c d) (s : IdentityExpr d e),
      FourfoldRouteCertificate p q r s

/-- **Bounded computational-path adequacy theorem.**

The semantic CwF validates substitution and the `Pi`, `Sigma`, `Nat`,
universe-code, and equality-factored identity rules.  Independently,
`raw_syntax` validates the de Bruijn source calculus in its computational-path
term model, including typed computation, source-only identity rewrites, and
restricted endpoint reflection.  The adjacent identity fields state the exact
boundary: equality-factored elimination computes, while ordinary
trace-sensitive J for raw `Path` is unavailable.  This theorem makes no
initiality, normalization, univalence, or HIT claim. -/
def computational_path_adequacy : ComputationalPathAdequacy.{u, v} where
  type_formers := type_former_adequacy
  substitution := substitution_adequacy
  rewrite_sound := fun h => identity_rweq_sound h
  raw_syntax := RawMLTT.raw_computational_path_adequacy
  raw_identity_rewrite_sound := fun h => RawMLTT.identity_rweq_sound h
  raw_endpoint_conservativity := RawMLTT.term_model_endpoint_adequacy
  endpoint_sound_complete := endpoint_adequacy
  contextual_sound_complete := judgment_adequacy
  raw_eq_factored_identity_beta := RawMLTT.eqJ_beta_path
  eq_factored_identity_beta := proofInsensitiveJ_refl
  trace_sensitive_boundary := no_traceSensitiveJ
  fourfold_routes := fourfold_routes

end

end MLTTAdequacy
end TypeTheory
end Path
end ComputationalPaths
